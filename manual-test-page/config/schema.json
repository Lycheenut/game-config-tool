{
    "version": 1,
    "tables": {
        "items": {
            "path": "items.csv",
            "fields": [
                {
                    "key": "id",
                    "type": "number",
                    "description": "ID"
                },
                {
                    "key": "name",
                    "type": "string",
                    "description": "显示名称"
                },
                {
                    "key": "rarity",
                    "type": "number",
                    "description": "Rarity tier",
                    "numberConstraint": {
                        "kind": "enum",
                        "enum": "Rarity"
                    }
                },
                {
                    "key": "price",
                    "type": "number",
                    "description": "Shop price",
                    "numberConstraint": {
                        "kind": "number",
                        "min": 0,
                        "max": 9999
                    }
                },
                {
                    "key": "tags",
                    "type": "string[]",
                    "description": "Search tags"
                },
                {
                    "key": "stats",
                    "type": "json",
                    "description": "Combat stats",
                    "structure": "ItemStats"
                },
                {
                    "key": "params",
                    "type": "kvPairs",
                    "description": "可选参数",
                    "keyType": "string",
                    "valueType": "number"
                }
            ]
        }
    },
    "constants": {
        "game.settings": {
            "path": "game/settings.json",
            "description": "Runtime tuning values"
        }
    },
    "enums": {
        "Rarity": {
            "description": "Item rarity",
            "values": [
                {
                    "key": "Common",
                    "value": 1,
                    "description": "Common"
                },
                {
                    "key": "Rare",
                    "value": 2,
                    "description": "Rare"
                },
                {
                    "key": "Epic",
                    "value": 3,
                    "description": "Epic"
                }
            ]
        }
    },
    "structures": {
        "ItemStats": {
            "description": "Stats embedded in item rows",
            "fields": [
                {
                    "key": "attack",
                    "type": "number",
                    "description": "Attack bonus",
                    "numberConstraint": {
                        "kind": "number",
                        "min": 0
                    }
                },
                {
                    "key": "speed",
                    "type": "number",
                    "description": "Attack speed"
                },
                {
                    "key": "unique",
                    "type": "boolean",
                    "description": "Unique item"
                }
            ]
        }
    }
}
